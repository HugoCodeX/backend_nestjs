# API Gateway — variables de entorno (ejemplo)
# Copia este archivo a `.env` y rellena los valores. NO commitees el `.env`.

# Puerto HTTP del gateway (entrada única para el cliente)
PORT=3000

# Redis (usado por el rate limiter). Ver docker-compose.yml
# Ejemplo dev: redis://localhost:6379
REDIS_URL=

# Rate limit por IP por minuto en el gateway (protección DDoS general)
RATE_LIMIT_PER_MIN=60

# URL del servicio de auth (interno, no expuesto al público)
# Dev con servicios en el host: http://localhost:3001
# Dev con Docker: http://auth-service:3001
AUTH_SERVICE_URL=

# URL del servicio de profile (interno, no expuesto al público)
# Dev con servicios en el host: http://localhost:3002
# Dev con Docker: http://profile-service:3002
PROFILE_SERVICE_URL=

# URL pública donde este gateway está expuesto.
# Better Auth la usa como issuer/audience del JWT. Debe coincidir con auth-service.
# Ejemplo dev: http://localhost:3000
BETTER_AUTH_URL=

# Origen del frontend permitido por CORS para llamar al gateway.
# Ejemplo dev: http://localhost:5173
FRONTEND_URL=
