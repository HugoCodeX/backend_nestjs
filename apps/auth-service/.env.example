# Auth Service — variables de entorno (ejemplo)
# Copia este archivo a `.env` y rellena los valores. NO commitees el `.env`.

# Puerto HTTP del servicio
PORT=3001

# Cadena de conexión a Postgres (Docker local: auth-postgres)
# Formato: postgres://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL=

# Better Auth — usado para cifrar claves privadas JWKS y firmar cookies.
# REQUERIDO. Mínimo 32 caracteres. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=

# URL pública del gateway (entrada única para el cliente).
# Se usa como issuer del JWT, redirects y validación CORS.
# Ejemplo dev: http://localhost:3000
BETTER_AUTH_URL=

# Origen del frontend permitido por CORS para llamar a la API de auth.
# Ejemplo dev: http://localhost:5173
FRONTEND_URL=

# Claim `aud` del JWT. Debe coincidir con el valor en profile-service.
JWT_AUDIENCE=

# Proveedor de email (Resend). Opcional en dev, REQUERIDO en producción.
# Si se deja vacío en dev, los emails se imprimen en consola.
# Obtén una API key en https://resend.com/api-keys
RESEND_API_KEY=

# Email remitente. Debe ser un dominio verificado en Resend.
# Para pruebas en dev puedes usar el sandbox: onboarding@resend.dev
RESEND_FROM_EMAIL=
