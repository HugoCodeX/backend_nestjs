# Profile Service — variables de entorno (ejemplo)
# Copia este archivo a `.env` y rellena los valores. NO commitees el `.env`.

# Puerto HTTP del servicio
PORT=3002

# Cadena de conexión a Postgres (Docker local: profile-postgres)
# Formato: postgres://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL=

# URL pública del gateway. Se usa para obtener las claves JWKS
# y verificar los JWT firmados por auth-service.
# Debe coincidir con el BETTER_AUTH_URL del gateway y auth-service.
# Ejemplo dev: http://localhost:3000
BETTER_AUTH_URL=

# Issuer esperado en el claim `iss` del JWT. Debe ser igual a BETTER_AUTH_URL.
JWT_ISSUER=

# Audience esperado en el claim `aud` del JWT.
# Debe coincidir con el JWT_AUDIENCE del auth-service.
JWT_AUDIENCE=
